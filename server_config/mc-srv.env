# General Configuration
TZ=Europe/Istanbul

# Server Configuration
EULA=TRUE
VERSION=1.21.1
#TYPE=NEOFORGE
MEMORY=8G
USE_SIMD_FLAGS=true
USE_AIKAR_FLAGS=true
NETWORK_COMPRESSION_THRESHOLD=1024
ENABLE_ROLLING_LOGS=true

# Server Properties
ALLOW_FLIGHT=true
MAX_PLAYERS=2
ICON=/srv-icon.png
ONLINE_MODE=true
DIFFICULTY=2
ENABLE_COMMAND_BLOCK=false
VIEW_DISTANCE=14
SIMULATION_DISTANCE=10
LEVEL=aoc_creative_tsko

# VanillaTweaks
#VANILLATWEAKS_FILE="/extras/vt-datapacks.json,/extras/vt-craftingtweaks.json,/extras/vt-resourcepacks.json"
VANILLATWEAKS_FILE="/extras/vt-datapacks.json,/extras/vt-craftingtweaks.json"

# Resource Pack
#RESOURCE_PACK=https://drive.usercontent.google.com/download?id=1EFmUQHVRUNnMNaIHscAu5VcJ5gjihQDF
#RESOURCE_PACK_ID=04dbab8b-607c-4186-a2ca-70b114cc07da
#RESOURCE_PACK_SHA1=7DFF448A3C170B453E2A7C0175AE84D76B91B2E2
RESOURCE_PACK_ENFORCE=false

# Server Modpack
MODPACK_PLATFORM=AUTO_CURSEFORGE
CF_SLUG=aoc
#CF_EXCLUDE_INCLUDE_FILE=/extras/cf-exclude-include.json
CF_FORCE_SYNCHRONIZE=false

# Mods
CURSEFORGE_FILES=@/extras/cf-mods.txt
#MODS_FILE=/extras/url-mods.txt

# Modrinth
# Projects are listed in extras/mr-projects.env
#MODRINTH_DOWNLOAD_DEPENDENCIES=required